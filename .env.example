NEXT_PUBLIC_APP_URL=http://localhost:3000
# Runtime app connection string used by Next.js server code and the Prisma adapter.
# Keep `sslmode=require`. Prefer the pooled/runtime URL if your cluster exposes one.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:25060/ipetzo?sslmode=require

# Optional direct Prisma CLI connection for migrations/introspection.
# Prefer the non-pooled/direct database URL if DigitalOcean provides one.
# If omitted, Prisma CLI falls back to DATABASE_URL.
DIRECT_URL=postgresql://USER:PASSWORD@HOST:25060/ipetzo?sslmode=require

# Optional runtime-only escape hatch for local droplet environments where the host
# CA store cannot validate the managed database certificate chain yet.
# `false` keeps TLS enabled but relaxes certificate verification in app runtime code.
# Leave this as `true` unless you have that specific local trust-store issue.
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# CI/build-only workflows may leave DATABASE_URL and DIRECT_URL unset.
# Prisma client generation stays safe in that case because prisma.config.ts
# falls back to a placeholder URL for commands that do not need a live database.

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
RESEND_API_KEY=re_your_resend_api_key
OPENAI_API_KEY=sk-your_openai_api_key
GOOGLE_PLACES_API_KEY=your_google_places_api_key
DO_SPACES_KEY=your_do_spaces_key
DO_SPACES_SECRET=your_do_spaces_secret
DO_SPACES_BUCKET=your_do_spaces_bucket
DO_SPACES_REGION=your_do_spaces_region
DO_SPACES_ENDPOINT=https://your-region.digitaloceanspaces.com
REDIS_URL=redis://USER:PASSWORD@HOST:6379/0
