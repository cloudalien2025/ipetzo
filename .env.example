NEXT_PUBLIC_APP_URL=http://localhost:3000
# DigitalOcean Managed PostgreSQL runtime connection string.
# Keep sslmode=require and prefer the pooled URL here if your cluster exposes one.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:25060/ipetzo?sslmode=require

# Optional direct connection for future Prisma migrations/introspection.
# Use the non-pooled database URL here if DigitalOcean provides one.
DIRECT_URL=postgresql://USER:PASSWORD@HOST:25060/ipetzo?sslmode=require

# Optional: set to false only if your local CA store cannot validate the managed DB certificate chain.
DATABASE_SSL_REJECT_UNAUTHORIZED=true

CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
RESEND_API_KEY=re_your_resend_api_key
OPENAI_API_KEY=sk-your_openai_api_key
GOOGLE_PLACES_API_KEY=your_google_places_api_key
DO_SPACES_KEY=your_do_spaces_key
DO_SPACES_SECRET=your_do_spaces_secret
DO_SPACES_BUCKET=your_do_spaces_bucket
DO_SPACES_REGION=your_do_spaces_region
DO_SPACES_ENDPOINT=https://your-region.digitaloceanspaces.com
REDIS_URL=redis://USER:PASSWORD@HOST:6379/0
